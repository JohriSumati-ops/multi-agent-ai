# Copy this file to `.env` in the backend/ root and fill in real values.
# Never commit a real .env file.

# --- Application ---
APP_NAME="Multi-Agent Research Assistant"
APP_VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=true

# --- API ---
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# --- Database ---
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/research_assistant
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Auth (primitives built in Phase 1; register/login routes added in Phase 2) ---
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- Document upload (Phase 2) ---
UPLOAD_DIR=./storage/uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_DOCUMENT_EXTENSIONS=["pdf","txt","md","docx"]

# --- Future AI-module placeholders (unused until later phases) ---
DEFAULT_LLM_PROVIDER=claude
GRAPH_DB_URL=not-configured

# --- Phase 3: Semantic Retrieval Layer ---
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
VECTOR_STORE_URL=./storage/vector_store
EMBEDDING_BATCH_SIZE=32
EMBEDDING_CACHE_SIZE=10000
RETRIEVAL_TOP_K_DEFAULT=5
RETRIEVAL_SIMILARITY_THRESHOLD=0.3

# --- Phase 4: Memory System ---
MEMORY_VECTOR_STORE_URL=./storage/memory_vector_store
SHORT_TERM_MEMORY_TTL_DAYS=7
SHORT_TERM_MEMORY_MAX_ITEMS=50
SESSION_MEMORY_TTL_MINUTES=30
LONG_TERM_MEMORY_MAX_ITEMS=5000

# --- Phase 5: Orchestration / Intelligence Layer ---
ORCHESTRATION_MAX_WORKERS=4
ORCHESTRATION_DEFAULT_TASK_TIMEOUT_SECONDS=30.0
ORCHESTRATION_DEFAULT_MAX_RETRIES=2
